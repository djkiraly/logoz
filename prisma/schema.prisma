generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model AdminSession {
  id        String    @id @default(cuid())
  token     String    @unique
  userId    String
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime  @default(now())
  user      AdminUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([expiresAt])
  @@index([token])
  @@index([userId])
}

model AdminUser {
  id                       String         @id @default(cuid())
  email                    String         @unique
  passwordHash             String
  name                     String
  role                     AdminRole      @default(ADMIN)
  isActive                 Boolean        @default(true)
  lastLoginAt              DateTime?
  createdAt                DateTime       @default(now())
  updatedAt                DateTime @updatedAt
  emailVerified            Boolean        @default(false)
  verificationToken        String?        @unique
  verificationTokenExpiry  DateTime?
  passwordResetToken       String?        @unique
  passwordResetTokenExpiry DateTime?
  sessions                 AdminSession[]
  auditLogs                AuditLog[]
  Quote                    Quote[]

  @@index([email])
  @@index([passwordResetToken])
  @@index([role])
  @@index([verificationToken])
}

model AnalyticsSession {
  id               String    @id @default(cuid())
  sessionId        String    @unique
  firstPage        String
  landingPage      String
  referrer         String?
  utmSource        String?
  utmMedium        String?
  utmCampaign      String?
  pageCount        Int       @default(1)
  totalDuration    Int       @default(0)
  country          String?
  region           String?
  city             String?
  deviceType       String?
  browser          String?
  os               String?
  ipAddress        String?
  startedAt        DateTime  @default(now())
  lastActiveAt     DateTime  @default(now())
  endedAt          DateTime?
  convertedToQuote Boolean   @default(false)
  quoteId          String?

  @@index([convertedToQuote])
  @@index([country])
  @@index([deviceType])
  @@index([sessionId])
  @@index([startedAt(sort: Desc)])
  @@index([utmSource])
}

model AuditLog {
  id        String    @id @default(cuid())
  userId    String
  action    String
  entity    String
  entityId  String?
  details   Json?
  ipAddress String?
  createdAt DateTime  @default(now())
  user      AdminUser @relation(fields: [userId], references: [id])

  @@index([action])
  @@index([createdAt(sort: Desc)])
  @@index([entity])
  @@index([userId])
}

model ArtworkVersion {
  id              String    @id @default(cuid())
  quoteId         String
  version         Int
  url             String
  fileName        String
  status          String    @default("PENDING")
  sentAt          DateTime?
  approvedAt      DateTime?
  declinedAt      DateTime?
  customerNotes   String?
  uploadedById    String?
  uploadedByName  String?
  uploadedByEmail String?
  createdAt       DateTime  @default(now())
  quote           Quote     @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  @@index([quoteId])
  @@index([version])
}

model Category {
  id          String     @id @default(cuid())
  slug        String     @unique
  title       String
  description String
  featured    Boolean    @default(false)
  imageUrl    String?
  markupPercent Float?
  products    Product[]
  services    Service[]
  suppliers   Supplier[] @relation("SupplierCategories")

  @@index([featured, title])
}

model Collection {
  id          String    @id @default(cuid())
  slug        String    @unique
  name        String
  description String
  heroImage   String?
  designs     Design[]
  products    Product[] @relation("CollectionProducts")
}

model Customer {
  id                   String         @id @default(cuid())
  companyName          String?
  customerType         CustomerType   @default(BUSINESS)
  website              String?
  industry             String?
  employeeCount        String?
  annualRevenue        String?
  contactName          String
  contactTitle         String?
  email                String         @unique
  phone                String?
  mobilePhone          String?
  addressLine1         String?
  addressLine2         String?
  city                 String?
  state                String?
  postalCode           String?
  country              String?        @default("USA")
  shippingAddressLine1 String?
  shippingAddressLine2 String?
  shippingCity         String?
  shippingState        String?
  shippingPostalCode   String?
  shippingCountry      String?
  status               CustomerStatus @default(LEAD)
  source               String?
  assignedTo           String?
  tags                 String[]
  taxExempt            Boolean        @default(false)
  taxId                String?
  paymentTerms         String?
  creditLimit          Decimal?       @db.Money
  preferredContact     String?
  marketingOptIn       Boolean        @default(true)
  notes                String?
  lastContactAt        DateTime?
  createdAt            DateTime       @default(now())
  updatedAt            DateTime @updatedAt
  quotes               Quote[]

  @@index([companyName])
  @@index([createdAt(sort: Desc)])
  @@index([customerType])
  @@index([email])
  @@index([status])
}

model DailyAnalytics {
  id                 String   @id @default(cuid())
  date               DateTime @unique @db.Date
  pageViews          Int      @default(0)
  uniqueVisitors     Int      @default(0)
  newVisitors        Int      @default(0)
  returningVisitors  Int      @default(0)
  avgSessionDuration Int      @default(0)
  avgPageViews       Decimal  @default(0)
  bounceRate         Decimal  @default(0)
  quotesStarted      Int      @default(0)
  quotesSubmitted    Int      @default(0)
  quotesApproved     Int      @default(0)
  conversionRate     Decimal  @default(0)
  productViews       Int      @default(0)
  topProducts        Json?
  topCountries       Json?
  desktopVisits      Int      @default(0)
  mobileVisits       Int      @default(0)
  tabletVisits       Int      @default(0)
  quotesValue        Decimal  @default(0) @db.Money
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([date(sort: Desc)])
}

model Design {
  id           String      @id @default(cuid())
  title        String
  description  String?
  previewUrl   String
  sourceFile   String?
  tags         String[]
  collectionId String?
  featured     Boolean     @default(false)
  collection   Collection? @relation(fields: [collectionId], references: [id])
  products     Product[]

  @@index([collectionId])
  @@index([featured])
}

model EmailConfig {
  id                Int       @id @default(1)
  provider          String    @default("gmail")
  gmailClientId     String?
  gmailClientSecret String?
  gmailRefreshToken String?
  gmailAccessToken  String?
  gmailTokenExpiry  DateTime?
  fromName          String    @default("Logoz Custom")
  fromEmail         String?
  replyToEmail      String?
  isConfigured      Boolean   @default(false)
  lastTestedAt      DateTime?
  lastTestStatus    String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime @updatedAt
}

model EntityActivity {
  id           String       @id @default(cuid())
  entityType   EntityType
  entityId     String
  activityType ActivityType
  userId       String?
  sessionId    String?
  ipAddress    String?
  oldValue     Json?
  newValue     Json?
  metadata     Json?
  createdAt    DateTime     @default(now())

  @@index([activityType])
  @@index([createdAt(sort: Desc)])
  @@index([entityId])
  @@index([entityType])
  @@index([userId])
}

model Faq {
  id       String  @id @default(cuid())
  question String  @unique
  answer   String
  category String?

  @@index([category])
}

model NotificationLog {
  id             String              @id @default(cuid())
  type           NotificationType
  channel        NotificationChannel
  recipientEmail String?
  recipientPhone String?
  recipientName  String?
  subject        String?
  body           String?
  status         String              @default("pending")
  errorMessage   String?
  sentAt         DateTime?
  quoteId        String?
  customerId     String?
  userId         String?
  createdAt      DateTime            @default(now())

  @@index([createdAt(sort: Desc)])
  @@index([customerId])
  @@index([quoteId])
  @@index([status])
  @@index([type])
}

model NotificationSetting {
  id              String              @id @default(cuid())
  type            NotificationType    @unique
  name            String
  description     String?
  channel         NotificationChannel @default(EMAIL)
  enabled         Boolean             @default(false)
  subject         String?
  bodyTemplate    String?
  recipientEmails String[]
  createdAt       DateTime            @default(now())
  updatedAt       DateTime @updatedAt

  @@index([enabled])
  @@index([type])
}

model PageView {
  id          String   @id @default(cuid())
  path        String
  referrer    String?
  userAgent   String?
  ipAddress   String?
  sessionId   String?
  createdAt   DateTime @default(now())
  browser     String?
  city        String?
  country     String?
  deviceType  String?
  duration    Int?
  exitPage    Boolean  @default(false)
  os          String?
  region      String?
  scrollDepth Int?
  isAdmin     Boolean  @default(false)

  @@index([country])
  @@index([createdAt(sort: Desc)])
  @@index([deviceType])
  @@index([isAdmin])
  @@index([path])
  @@index([sessionId])
}

model Product {
  id                 String              @id @default(cuid())
  sku                String              @unique
  name               String
  description        String
  heroImageUrl       String?
  gallery            String[]
  colorImages        Json?
  basePrice          Decimal             @db.Money
  minQuantity        Int                 @default(1)
  categoryId         String
  supplierId         String?
  fulfillment        FulfillmentMethod[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime @updatedAt
  featured           Boolean             @default(false)
  visible            Boolean             @default(false)
  cost               Decimal?            @db.Money
  priceOverridden    Boolean             @default(false)
  imageSource        ImageSource         @default(LOCAL)
  keywords           String[]
  lastSyncedAt       DateTime?
  priceCode          String?
  productStatus      ProductStatus       @default(ACTIVE)
  sanmarBrand        String?
  sanmarCategory     String?
  sanmarInventoryKey String?
  sanmarStyleId      String?             @unique
  syncSource         String?
  category           Category            @relation(fields: [categoryId], references: [id])
  supplier           Supplier?           @relation(fields: [supplierId], references: [id])
  productViews       ProductView[]
  lineItems          QuoteLineItem[]
  variants           Variant[]
  collections        Collection[]        @relation("CollectionProducts")
  designs            Design[]

  @@index([categoryId])
  @@index([createdAt(sort: Desc)])
  @@index([productStatus])
  @@index([sanmarStyleId])
  @@index([supplierId])
  @@index([visible])
}

model ProductView {
  id           String   @id @default(cuid())
  productId    String
  sessionId    String?
  ipAddress    String?
  referrer     String?
  duration     Int?
  addedToQuote Boolean  @default(false)
  createdAt    DateTime @default(now())
  product      Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([createdAt(sort: Desc)])
  @@index([productId])
  @@index([sessionId])
}

model Quote {
  id                String          @id @default(cuid())
  quoteNumber       String          @unique
  customerId        String?
  customerName      String?
  customerEmail     String?
  customerPhone     String?
  customerCompany   String?
  title             String?
  notes             String?
  internalNotes     String?
  validUntil        DateTime?
  requestedDelivery DateTime?
  subtotal          Decimal         @default(0) @db.Money
  discount          Decimal         @default(0) @db.Money
  discountType      DiscountType    @default(FIXED)
  tax               Decimal         @default(0) @db.Money
  taxRate           Decimal         @default(0)
  shipping          Decimal         @default(0) @db.Money
  total             Decimal         @default(0) @db.Money
  status            QuoteStatus     @default(PENDING)
  sentAt            DateTime?
  approvedAt        DateTime?
  createdBy         String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime @updatedAt
  ownerId           String?
  lastModifiedAt    DateTime        @default(now())
  accessToken          String?         @unique
  accessTokenExpiresAt DateTime?
  declinedAt           DateTime?
  discountValue     Decimal         @default(0)
  artworkApprovedAt DateTime?
  artworkDeclinedAt DateTime?
  artworkFileName   String?
  artworkNotes      String?
  artworkRequired   Boolean         @default(false)
  artworkSentAt     DateTime?
  artworkToken          String?         @unique
  artworkTokenExpiresAt DateTime?
  artworkUrl            String?
  artworkVersion    Int             @default(1)
  customer          Customer?       @relation(fields: [customerId], references: [id])
  owner             AdminUser?      @relation(fields: [ownerId], references: [id])
  artworkVersions   ArtworkVersion[]
  auditLog          QuoteAuditLog[]
  lineItems         QuoteLineItem[]

  @@index([createdAt(sort: Desc)])
  @@index([customerId])
  @@index([lastModifiedAt(sort: Desc)])
  @@index([ownerId])
  @@index([quoteNumber])
  @@index([status])
}

model QuoteAuditLog {
  id            String              @id @default(cuid())
  // Nullable so the audit trail SURVIVES quote deletion (SetNull) instead of
  // being cascade-wiped. quoteNumber is denormalized for traceability once the
  // parent quote is gone.
  quoteId       String?
  quoteNumber   String?
  action        QuoteAuditAction
  description   String
  actorType     QuoteAuditActorType @default(ADMIN)
  actorId       String?
  actorName     String?
  actorEmail    String?
  previousValue Json?
  newValue      Json?
  metadata      Json?
  createdAt     DateTime            @default(now())
  quote         Quote?              @relation(fields: [quoteId], references: [id], onDelete: SetNull)

  @@index([action])
  @@index([createdAt(sort: Desc)])
  @@index([quoteId])
}

model QuoteFunnelEvent {
  id         String           @id @default(cuid())
  stage      QuoteFunnelStage
  sessionId  String?
  quoteId    String?
  customerId String?
  productIds String[]
  metadata   Json?
  createdAt  DateTime         @default(now())

  @@index([createdAt(sort: Desc)])
  @@index([quoteId])
  @@index([sessionId])
  @@index([stage])
}

model QuoteLineItem {
  id             String             @id @default(cuid())
  quoteId        String
  itemType       LineItemType       @default(PRODUCT)
  productId      String?
  supplierId     String?
  sku            String?
  name           String
  description    String?
  serviceType    FulfillmentMethod?
  serviceOptions Json?
  quantity       Int                @default(1)
  unitPrice      Decimal            @db.Money
  discount       Decimal            @default(0) @db.Money
  total          Decimal            @db.Money
  sortOrder      Int                @default(0)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime @updatedAt
  product        Product?           @relation(fields: [productId], references: [id])
  quote          Quote              @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  supplier       Supplier?          @relation(fields: [supplierId], references: [id])

  @@index([productId])
  @@index([quoteId])
  @@index([supplierId])
}

model QuoteRequest {
  id          String            @id @default(cuid())
  contactName String
  company     String?
  email       String
  phone       String?
  dueDate     DateTime?
  quantity    Int
  serviceType FulfillmentMethod
  notes       String?
  productId   String?
  status      QuoteStatus       @default(PENDING)
  attachments String[]
  createdAt   DateTime          @default(now())
  updatedAt   DateTime @updatedAt

  @@index([createdAt(sort: Desc)])
  @@index([email])
  @@index([serviceType])
  @@index([status])
}

model SanMarCategoryMapping {
  id              String   @id @default(cuid())
  sanmarCategory  String   @unique
  localCategoryId String?
  autoCreate      Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([sanmarCategory])
}

model SanMarSyncConfig {
  id                  Int       @id @default(1)
  customerNumber      String?
  username            String?
  passwordEncrypted   String?
  syncEnabled         Boolean   @default(false)
  autoSyncEnabled     Boolean   @default(false)
  autoSyncSchedule    String?
  defaultVisibility   Boolean   @default(false)
  defaultCategoryId   String?
  importDiscontinued  Boolean   @default(false)
  categoryFilter      String[]
  brandFilter         String[]
  lastBulkSyncAt      DateTime?
  lastDeltaSyncAt     DateTime?
  lastInventorySyncAt DateTime?
  lastPricingSyncAt   DateTime?
  totalProductsSynced Int       @default(0)
  totalVariantsSynced Int       @default(0)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime @updatedAt
}

model SanMarSyncLog {
  id              String           @id @default(cuid())
  syncType        SanMarSyncType
  status          SanMarSyncStatus @default(PENDING)
  totalItems      Int              @default(0)
  processedItems  Int              @default(0)
  productsAdded   Int              @default(0)
  productsUpdated Int              @default(0)
  productsSkipped Int              @default(0)
  variantsAdded   Int              @default(0)
  variantsUpdated Int              @default(0)
  suppliersAdded  Int              @default(0)
  errorCount      Int              @default(0)
  errors          Json?
  triggeredBy     String?
  options         Json?
  startedAt       DateTime         @default(now())
  completedAt     DateTime?

  @@index([startedAt(sort: Desc)])
  @@index([status])
  @@index([syncType])
}

model Service {
  id        String              @id @default(cuid())
  slug      String              @unique
  title     String
  summary   String
  body      String
  heroImage String?
  methods   FulfillmentMethod[]
  ctaLabel  String?
  ctaLink   String?
  categories  Category[]
}

model SiteSetting {
  id                 Int     @id @default(1)
  defaultMarkupPercent Float @default(0)
  siteName           String  @default("Logoz Custom")
  heroTagline        String  @default("Cloud print operating system")
  heroHeading        String
  heroCopy           String
  ctaLabel           String
  ctaLink            String
  contactEmail       String  @unique
  contactPhone       String
  address            String
  announcement       String?
  theme              Json?
  gcsConfig          Json?
  recaptchaEnabled   Boolean @default(false)
  recaptchaSecretKey String?
  recaptchaSiteKey   String?
  bannerEnabled      Boolean @default(true)
  headerCtaLabel     String  @default("Build a design")
  headerCtaLink      String  @default("/design-studio")
  headerCtaEnabled   Boolean @default(true)
  copyrightText      String  @default("Crafted in the cloud.")
  faviconUrl         String?
  logoUrl            String?
  heroImageUrl       String?
  heroVideoEnabled   Boolean @default(false)
  heroVideoUrl       String?
  heroVideoAutoplay  Boolean @default(true)
  heroVideoMuted     Boolean @default(true)
  heroVideoDuration  Int?
}

model SmsConfig {
  id             Int       @id @default(1)
  provider       String    @default("twilio")
  accountSid     String?
  authToken      String?
  fromNumber     String?
  isConfigured   Boolean   @default(false)
  lastTestedAt   DateTime?
  lastTestStatus String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime @updatedAt
}

model Supplier {
  id                 String          @id @default(cuid())
  name               String          @unique
  logoUrl            String?
  website            String?
  description        String?
  leadTimeDays       Int?
  featured           Boolean         @default(false)
  embellishRequired  Boolean         @default(false)
  isSanmarBrand      Boolean         @default(false)
  mapRestricted      Boolean         @default(false)
  sanmarBrandLogoUrl String?
  sanmarBrandName    String?         @unique
  capabilities       String[]        @default([])
  products           Product[]
  lineItems          QuoteLineItem[]
  category           Category[]      @relation("SupplierCategories")

  @@index([featured, name])
  @@index([sanmarBrandName])
}

model Testimonial {
  id        String  @id @default(cuid())
  author    String  @unique
  title     String?
  company   String?
  quote     String
  rating    Int     @default(5)
  avatarUrl String?

  @@index([rating(sort: Desc)])
}

model Variant {
  id                 String   @id @default(cuid())
  productId          String
  color              String
  size               String
  priceAdjust        Decimal? @db.Money
  inventory          Int?     @default(0)
  casePrice          Decimal? @db.Money
  caseSize           Int?
  gtin               String?
  piecePrice         Decimal? @db.Money
  pieceWeight        Decimal?
  salePrice          Decimal? @db.Money
  sanmarCatalogColor String?
  sanmarPartId       String?
  // NOT unique: SanMar UNIQUE_KEY can be duplicated/corrupted in catalog
  // exports, and a global unique here would fail a whole style's variant
  // transaction. Variant identity is (productId, color, size).
  sanmarUniqueKey    String?
  product            Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, color, size])
  @@index([productId])
  @@index([sanmarUniqueKey])
}

enum ActivityType {
  CREATED
  UPDATED
  DELETED
  VIEWED
  PUBLISHED
  UNPUBLISHED
  STATUS_CHANGED
}

enum AdminRole {
  SUPER_ADMIN
  ADMIN
  EDITOR
}

enum CustomerStatus {
  LEAD
  PROSPECT
  ACTIVE
  INACTIVE
  CHURNED
}

enum CustomerType {
  INDIVIDUAL
  BUSINESS
  NONPROFIT
  GOVERNMENT
  EDUCATION
}

enum DiscountType {
  FIXED
  PERCENTAGE
}

enum EntityType {
  PRODUCT
  VENDOR
  QUOTE
  CUSTOMER
  CATEGORY
  USER
}

enum FulfillmentMethod {
  EMBROIDERY
  SCREEN_PRINT
  DTG
  VINYL
  SUBLIMATION
  LASER
  PROMO
}

enum ImageSource {
  LOCAL
  REMOTE
  HYBRID
}

enum LineItemType {
  PRODUCT
  SERVICE
  CUSTOM
  SETUP_FEE
  SHIPPING
  DISCOUNT
}

enum NotificationChannel {
  EMAIL
  SMS
}

enum NotificationType {
  INTERNAL_QUOTE_CREATED
  INTERNAL_QUOTE_STATUS_CHANGE
  INTERNAL_USER_VERIFICATION
  CUSTOMER_QUOTE_SENT
  CUSTOMER_QUOTE_STATUS_CHANGE
  INTERNAL_ARTWORK_RESPONSE
  CUSTOMER_ARTWORK_APPROVAL
}

enum ProductStatus {
  ACTIVE
  DISCONTINUED
  COMING_SOON
  NEW
}

enum QuoteAuditAction {
  CREATED
  UPDATED
  STATUS_CHANGED
  SENT_TO_CUSTOMER
  APPROVED_BY_CUSTOMER
  DECLINED_BY_CUSTOMER
  LINE_ITEM_ADDED
  LINE_ITEM_UPDATED
  LINE_ITEM_REMOVED
  CUSTOMER_CHANGED
  OWNER_CHANGED
  PRICING_UPDATED
  DELETED
  ARTWORK_UPLOADED
  ARTWORK_SENT_TO_CUSTOMER
  ARTWORK_APPROVED_BY_CUSTOMER
  ARTWORK_DECLINED_BY_CUSTOMER
  ARTWORK_UPDATED
}

enum QuoteAuditActorType {
  ADMIN
  CUSTOMER
  SYSTEM
}

enum QuoteFunnelStage {
  VIEWED_PRODUCTS
  STARTED_QUOTE
  ADDED_ITEMS
  SUBMITTED_INFO
  QUOTE_SENT
  QUOTE_APPROVED
  QUOTE_REJECTED
}

enum QuoteStatus {
  PENDING
  REVIEWING
  SENT
  APPROVED
  ARCHIVED
  DECLINED
  ARTWORK_PENDING
  ARTWORK_APPROVED
  ARTWORK_DECLINED
  // Order/fulfillment states (downstream of an approved quote)
  IN_PRODUCTION
  FULFILLED
  SHIPPED
  COMPLETED
}

enum SanMarSyncStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

enum SanMarSyncType {
  BULK
  DELTA
  INVENTORY
  PRICING
  MEDIA
}
