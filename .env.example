# ===========================================
# Logoz Cloud Print Studio - Environment Variables
# ===========================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# ===========================================
# Database Configuration (Neon PostgreSQL)
# ===========================================
# Sign up at https://neon.tech for a free serverless PostgreSQL database
#
# Connection string format for Neon:
# postgresql://[user]:[password]@[endpoint-id].neon.tech/[database]?sslmode=require
#
# IMPORTANT: Neon uses connection pooling. Use the pooled connection for your app:
# - Pooled (for app): Use the "-pooler" hostname for DATABASE_URL
# - Direct (for migrations): Use the hostname WITHOUT "-pooler" for DIRECT_URL
#
# Example Neon connection strings:
# DATABASE_URL="postgresql://neondb_owner:abc123@ep-cool-darkness-123456-pooler.us-east-2.aws.neon.tech/neondb?sslmode=require"
# DIRECT_URL="postgresql://neondb_owner:abc123@ep-cool-darkness-123456.us-east-2.aws.neon.tech/neondb?sslmode=require"

# Pooled connection for application queries (recommended for serverless)
DATABASE_URL="postgresql://user:password@ep-example-123456-pooler.us-east-2.aws.neon.tech/neondb?sslmode=require"

# Direct connection for Prisma migrations (bypasses connection pooler)
# NOTE: Use the hostname WITHOUT "-pooler" — PgBouncer can interfere with migrations
DIRECT_URL="postgresql://user:password@ep-example-123456.us-east-2.aws.neon.tech/neondb?sslmode=require"

# Shadow database for Prisma migrations (optional — only needed for prisma migrate dev)
# Create a branch named "shadow" in your Neon project for this, or leave commented
# SHADOW_DATABASE_URL="postgresql://user:password@ep-example-123456.us-east-2.aws.neon.tech/neondb_shadow?sslmode=require"

# ===========================================
# Site Configuration
# ===========================================
# Public site name (shown in browser tab and headers)
NEXT_PUBLIC_SITE_NAME="Logoz Cloud Print Studio"

# Public site URL (used for CORS, absolute URLs, email links, and redirects)
# In production, set to your actual domain (e.g., https://yourdomain.com)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Server-side site URL (used for email links and redirects when NEXT_PUBLIC_SITE_URL is not available)
# Set this to the same value as NEXT_PUBLIC_SITE_URL in production
SITE_URL="http://localhost:3000"

# Admin email for receiving quote notifications
ADMIN_CONTACT_EMAIL="hello@logoz.com"

# ===========================================
# Cron Jobs & Background Tasks
# ===========================================
# Secret token to authenticate cron job requests (e.g., SanMar sync)
# Generate with: openssl rand -hex 32
# CRON_SECRET=""

# ===========================================
# SanMar Integration (Optional)
# ===========================================
# Encryption key for SanMar API credentials stored in the database
# Generate with: openssl rand -hex 32
# IMPORTANT: Change from default in production!
# SANMAR_ENCRYPTION_KEY=""

# SanMar API environment: "test" or "production"
# SANMAR_ENVIRONMENT="test"

# ===========================================
# Rate Limiting (Optional - Upstash Redis)
# ===========================================
# Sign up at https://upstash.com for free Redis
# If not configured, falls back to in-memory rate limiting
# UPSTASH_REDIS_REST_URL=""
# UPSTASH_REDIS_REST_TOKEN=""

# ===========================================
# Email Notifications (Optional - Resend)
# ===========================================
# Sign up at https://resend.com for email sending
# RESEND_API_KEY=""

# ===========================================
# Error Monitoring (Optional - Sentry)
# ===========================================
# Sign up at https://sentry.io for error tracking
# SENTRY_DSN=""
# SENTRY_AUTH_TOKEN=""

# ===========================================
# Cloud Storage (Optional - Google Cloud Storage)
# ===========================================
# For storing uploaded designs and attachments
# CLOUD_STORAGE_BUCKET=""
# CLOUD_STORAGE_REGION=""

# ===========================================
# Server Configuration
# ===========================================
# Port to run the server on (default: 3000)
PORT="3000"

# ===========================================
# Logging
# ===========================================
# Log level: debug, info, warn, error
LOG_LEVEL="info"
